# Copy to .env (gitignored) and fill in.

# Claude API key — used to generate animations.
ANTHROPIC_API_KEY=sk-ant-...

# The sole admin's Google email. REQUIRED — the server refuses to boot without
# it. This account can see/control every frame and manage access.
ADMIN_EMAIL=leo@leomancinidesign.com

# Google OAuth Web client ID (NOT the secret). From Google Cloud Console →
# APIs & Services → Credentials. Without it, sign-in is unavailable.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Secret used to sign session-cookie JWTs. Generate a random 32+ byte value,
# e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, an ephemeral one is used (everyone is logged out on each restart).
SESSION_SECRET=
