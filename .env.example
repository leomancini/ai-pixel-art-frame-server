# Copy to .env (gitignored) and fill in.

# Claude API key — used to generate animations.
ANTHROPIC_API_KEY=sk-ant-...

# The sole admin's Google email. REQUIRED — the server refuses to boot without
# it. This account can see/control every frame and manage access.
ADMIN_EMAIL=leo@leomancinidesign.com

# Google OAuth Web client ID (NOT the secret). From Google Cloud Console →
# APIs & Services → Credentials. Without it, sign-in is unavailable.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Google OAuth client SECRET — only needed for the MCP server's Google login
# (the website's sign-in is a public GIS flow and uses no secret). Get it from
# the same OAuth client in Google Cloud Console. Also add this redirect URI to
# that client's "Authorized redirect URIs":  <MCP_BASE_URL>/oauth/google/callback
# Without it, the MCP endpoint still serves the unauthenticated frame
# (MCP_ANON_FRAME_SLUG) but no one can log in to control other frames.
GOOGLE_CLIENT_SECRET=

# Public origin (scheme + host, no path) the MCP authorization server advertises
# in its OAuth metadata and uses to build redirect URIs. Behind the TLS proxy set
# this to the public https origin, e.g. https://frames.example.com. Defaults to
# http://localhost:3136 for local development.
MCP_BASE_URL=

# The single frame slug the MCP endpoint serves WITHOUT authentication. Requests
# concerning this frame (and MCP discovery) need no token; every other frame
# requires a Google login. Defaults to frame-003.
MCP_ANON_FRAME_SLUG=frame-003

# Secret used to sign session-cookie JWTs. Generate a random 32+ byte value,
# e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, an ephemeral one is used (everyone is logged out on each restart).
SESSION_SECRET=
